# Ariadne's Thread — environment template
# Copy to .env and fill private values. Never commit .env.

# =============================================================================
# APP RUNTIME / LAUNCHER
# =============================================================================

# APP_ENV: Runtime mode. Use "development" on your laptop.
APP_ENV=development

# APP_VERSION: Displayed in /api/health and logs.
APP_VERSION=0.1.0

# LOG_LEVEL: Python logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# DATABASE_ECHO: Log every SQL statement (very noisy). Use only when debugging queries.
DATABASE_ECHO=false

# HOST: FastAPI bind address. 127.0.0.1 keeps the API local-only (safest for dev).
HOST=127.0.0.1

# PORT: Thread API port. 9622 = Ariadne's Thread. 9621 = Theseus (separate app).
PORT=9622

# FRONTEND_PORT: Next.js dev server port (spawned by python app.py).
FRONTEND_PORT=3000

# PUBLIC_APP_NAME: Shown in UI title and startup logs.
PUBLIC_APP_NAME=Ariadne's Thread

# NEXT_PUBLIC_API_URL: Base URL the Next.js UI uses to call FastAPI.
NEXT_PUBLIC_API_URL=http://127.0.0.1:9622

# AUTOSTART_FRONTEND: Deprecated (ignored). Command center is HTMX on PORT.
# Archived Next.js: python app.py --legacy-frontend  (or cd frontend && npm run dev)
AUTOSTART_FRONTEND=false

# ENABLE_STARTUP_WARMUP: Pre-load Ollama admin model, MCP manifest catalog, and skills registry.
ENABLE_STARTUP_WARMUP=true

# AUTOSTART_RESEARCH_PROVIDERS: Start SearXNG + Crawl4AI Docker profile on boot.
AUTOSTART_RESEARCH_PROVIDERS=true

# =============================================================================
# POSTGRESQL (Thread-only port — avoids conflict with other local Postgres)
# =============================================================================

# THREAD_POSTGRES_PORT: Host port for this project's Docker Postgres (not 5432).
THREAD_POSTGRES_PORT=55432

# DATABASE_URL: Async SQLAlchemy URL for workflow + intel tables (single database).
DATABASE_URL=postgresql+asyncpg://thread:thread@127.0.0.1:55432/thread

# DATABASE_POOL_SIZE: Connection pool size for FastAPI request handlers.
DATABASE_POOL_SIZE=10

# =============================================================================
# INTEL MIGRATION (one-time bulk zip/CSV → PostgreSQL COPY)
# =============================================================================

# INTEL_BULK_PRIME_DIR / INTEL_BULK_SUB_DIR: USASpending 10-year bulk chunks from capture-insights.
INTEL_BULK_PRIME_DIR=../capture-insights/data/raw/10year_bulk/prime
INTEL_BULK_SUB_DIR=../capture-insights/data/raw/10year_bulk/sub

# INTEL_MIGRATION_SOURCE: legacy DuckDB path (unused — bulk COPY is the migration path).
INTEL_MIGRATION_SOURCE=../capture-insights/data/capture.duckdb

# INTEL_AUTO_MIGRATE_ON_START: false recommended — use scripts/run-intel-migration.ps1
# in a separate window for the one-time load (resumable per zip, logs to .thread/).
INTEL_AUTO_MIGRATE_ON_START=false

# =============================================================================
# KNOWLEDGE VAULT (Obsidian / Karpathy brain)
# =============================================================================

# KNOWLEDGE_VAULT_PATH: Local Obsidian-compatible vault root (gitignored).
KNOWLEDGE_VAULT_PATH=knowledge/thread

# KNOWLEDGE_SEED_SOURCE: Existing vault to bootstrap from on first run.
KNOWLEDGE_SEED_SOURCE=../capture-insights/data/knowledge

# KNOWLEDGE_BOOTSTRAP_ON_START: Copy seed schema/global wiki if vault is empty.
KNOWLEDGE_BOOTSTRAP_ON_START=true

# REFERENCE_DOCS_ROOT: Briefing packet, call plan, risk register dictionaries.
REFERENCE_DOCS_ROOT=docs/reference

# GRAPH_EDGES_PATH: Lightweight relationship export (Neo4j-ready JSONL).
GRAPH_EDGES_PATH=data/graph/edges.jsonl

# =============================================================================
# AI PROVIDER KEYS
# =============================================================================

# XAI_API_KEY: xAI key for Grok — primary reasoning. https://console.x.ai
XAI_API_KEY=

# XAI_BASE_URL: OpenAI-compatible xAI endpoint.
XAI_BASE_URL=https://api.x.ai/v1

# =============================================================================
# AI MODEL DEFAULTS (cloud-primary reasoning, local admin offload)
# =============================================================================

# DEFAULT_LLM_PROVIDER: Primary provider for complex reasoning ("xai" recommended).
DEFAULT_LLM_PROVIDER=xai

# REASONING_LLM_MODEL: Grok model for strategy, packet fields, research synthesis, Education Studio.
REASONING_LLM_MODEL=grok-4.3

# LLM_FALLBACK_ENABLED: Admin/light tasks may use Ollama when configured.
LLM_FALLBACK_ENABLED=true

# LLM_MODEL_TEMPERATURE: Randomness (0.2–0.3 steadier for capture work).
LLM_MODEL_TEMPERATURE=0.3

# LLM_MAX_OUTPUT_TOKENS: Cap for long artifacts (grok-4.3 supports up to ~200k).
LLM_MAX_OUTPUT_TOKENS=8192

# LLM_TIMEOUT_SECONDS: Max wait for hosted model response.
LLM_TIMEOUT_SECONDS=120

# =============================================================================
# LOCAL MODEL DEFAULTS (admin / light tasks only)
# =============================================================================

# OLLAMA_HOST: Local Ollama base URL. https://ollama.com
OLLAMA_HOST=http://localhost:11434

# LOCAL_DAILY_MODEL: Ollama tag for vault polish, classification, draft scaffolding (8GB VRAM sweet spot).
LOCAL_DAILY_MODEL=qwen3:8b

# LOCAL_ADMIN_MODEL_ENABLED: Enable Ollama for low-risk admin assists.
LOCAL_ADMIN_MODEL_ENABLED=true

# OLLAMA_TEMPERATURE: Temperature for local admin model calls.
OLLAMA_TEMPERATURE=0.3

# =============================================================================
# EMBEDDING (OpenAI — xAI does not provide embeddings)
# Used by future vault semantic search. Not wired in MVP.
# https://platform.openai.com/docs/guides/embeddings
# =============================================================================

# EMBEDDING_BINDING: Provider id (openai).
EMBEDDING_BINDING=openai

# EMBEDDING_BINDING_HOST: OpenAI-compatible embeddings endpoint.
EMBEDDING_BINDING_HOST=https://api.openai.com/v1

# EMBEDDING_BINDING_API_KEY: OpenAI API key for embeddings.
EMBEDDING_BINDING_API_KEY=

# EMBEDDING_MODEL: Embedding model name.
EMBEDDING_MODEL=text-embedding-3-large

# EMBEDDING_DIM: Vector dimension (must match model).
EMBEDDING_DIM=3072

# =============================================================================
# WEB RESEARCH (free/local first — paid providers need approval gate)
# =============================================================================

# CRAWL4AI_BASE_URL: Local Crawl4AI for page crawl + markdown (Docker port 11235).
CRAWL4AI_BASE_URL=http://localhost:11235

# CRAWL4AI_API_TOKEN: Bearer token for Crawl4AI /crawl (image default: test_api_code).
CRAWL4AI_API_TOKEN=test_api_code

# SEARXNG_BASE_URL: Local SearXNG metasearch (Docker port 8080).
SEARXNG_BASE_URL=http://localhost:8080

# SERPAPI_API_KEY: Optional SerpApi fallback when SearXNG is insufficient.
SERPAPI_API_KEY=

# OLOSTEP_API_KEY: Optional Olostep search/scrape fallback.
OLOSTEP_API_KEY=

# FIRECRAWL_API_KEY: Optional Firecrawl for higher-quality crawls (uses credits).
FIRECRAWL_API_KEY=

# RESEARCH_REQUIRE_APPROVAL_FOR_PAID: Block paid provider spend without approval.
RESEARCH_REQUIRE_APPROVAL_FOR_PAID=true

# =============================================================================
# MCP / FEDERAL DATA (1102tools/federal-contracting-mcps)
# =============================================================================

# ENABLE_LIVE_MCPS: false = deterministic fake responses (offline dev).
ENABLE_LIVE_MCPS=true

# MCP subprocess keys — runtime injects only vars declared in each MCP's env_required[].
#
# No-key MCPs (work out of the box):
#   usaspending, ecfr, gsa_calc (future), gsa_perdiem (future), federal_register (future)
#
# Key-gated MCPs (set matching var when you vendor that MCP):

# SAM_GOV_API_KEY: SAM.gov entity/opportunity data. https://sam.gov/ → Request Public API Key
# (Legacy alias SAM_API_KEY also accepted by config.)
SAM_GOV_API_KEY=

# BLS_API_KEY: Bureau of Labor Statistics OEWS. https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# API_DATA_GOV_KEY: Single api.data.gov key (GSA Per Diem, Regulations.gov MCPs).
# https://api.data.gov/signup/
API_DATA_GOV_KEY=

# PERDIEM_API_KEY: gsa-perdiem-mcp reads this name; derive from api.data.gov key:
PERDIEM_API_KEY=${API_DATA_GOV_KEY}

# MCP_TOOL_TIMEOUT_SECONDS: Max seconds to wait for an MCP subprocess call.
MCP_TOOL_TIMEOUT_SECONDS=60

# =============================================================================
# SKILLS & LOCAL PATHS
# =============================================================================

# SKILLS_ROOT: Developer skills (skill-creator, datarepublican_intel, mcp_federal_tools).
SKILLS_ROOT=skills

# SKILL_RUNS_PATH: Auditable skill run artifacts (gitignored).
SKILL_RUNS_PATH=data/runs

# THREAD_STATE_DIR: Private runtime state (indexes, caches).
THREAD_STATE_DIR=.thread

# DEFAULT_NAICS: Default NAICS filter for intel signals and market queries.
DEFAULT_NAICS=561210

# =============================================================================
# DOCUMENT PARSING — MinerU default parser (GPU sidecar in .venv-mineru)
# One-time install: powershell -File scripts/install-mineru.ps1
# =============================================================================

# MINERU_ENABLED: Use MinerU as default parser on FAB document capture.
MINERU_ENABLED=true

# MINERU_AUTOSTART: Spawn mineru-api when python app.py starts (recommended).
MINERU_AUTOSTART=true

# MINERU_LOCAL_ENDPOINT: MinerU FastAPI base URL (Thread default port 8888).
MINERU_LOCAL_ENDPOINT=http://127.0.0.1:8888

# MINERU_LOCAL_BACKEND: hybrid-auto-engine (GPU, RTX 4060 8GB) | pipeline (CPU fallback).
MINERU_LOCAL_BACKEND=hybrid-auto-engine

# MINERU_LOCAL_PARSE_METHOD: auto | txt | ocr (pipeline/hybrid backends).
MINERU_LOCAL_PARSE_METHOD=auto

# MINERU_LANGUAGE: ch routes English in MinerU 3.4+; use ch for US gov PDFs.
MINERU_LANGUAGE=ch

# MINERU_PARSE_TIMEOUT_SECONDS: Sync /file_parse wait (large RFPs may need 600+).
MINERU_PARSE_TIMEOUT_SECONDS=600

# MINERU_STARTUP_TIMEOUT_SECONDS: Wait for mineru-api + VLM preload on first boot.
MINERU_STARTUP_TIMEOUT_SECONDS=300

# MINERU_VLM_PRELOAD: Preload hybrid VLM at startup (8GB VRAM: false — loads on first parse).
MINERU_VLM_PRELOAD=false

# MINERU_DOCKER_IMAGE: Reserved for future containerized MinerU deploy.
MINERU_DOCKER_IMAGE=

# =============================================================================
# GPU — passed to mineru-api subprocess (RTX 4060 8GB defaults)
# =============================================================================

CUDA_VISIBLE_DEVICES=0
MINERU_DEVICE_MODE=cuda
MINERU_HYBRID_BATCH_RATIO=8

# =============================================================================
# ORCHESTRATION — LangGraph skill chains + LangSmith tracing (deferred runtime)
# Route-first capture orchestration ships before LangGraph runtime adoption.
# Port family: API :9622, LangGraph Studio :9623, UI :3000, Postgres :55432.
# =============================================================================

# LANGGRAPH_ENABLED: Master switch for LangGraph chain executor (off until runtime lands).
LANGGRAPH_ENABLED=false

# THREAD_LANGGRAPH_STUDIO_AUTO_START: Spawn `langgraph dev` from python app.py when enabled.
# Legacy alias THESEUS_LANGGRAPH_STUDIO_AUTO_START still accepted during migration.
THREAD_LANGGRAPH_STUDIO_AUTO_START=false

# LANGGRAPH_STUDIO_HOST: Bind address for local LangGraph Studio dev server.
LANGGRAPH_STUDIO_HOST=127.0.0.1

# LANGGRAPH_STUDIO_PORT: Thread orchestration debug port (9623 — not Theseus :9621 or API :9622).
LANGGRAPH_STUDIO_PORT=9623

# LANGSMITH_API_KEY: LangSmith auth for trace UI + LangGraph Studio debugger.
# Free tier: 5,000 traces/month — https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=

# LANGCHAIN_API_KEY: LangChain SDK mirror; defaults to LANGSMITH_API_KEY when unset.
LANGCHAIN_API_KEY=${LANGSMITH_API_KEY}

# LANGSMITH_TRACING: Emit traces to LangSmith (disable to save quota during local dev).
LANGSMITH_TRACING=false

# LANGCHAIN_TRACING_V2: LangChain SDK tracing flag (keep in sync with LANGSMITH_TRACING).
LANGCHAIN_TRACING_V2=false

# LANGSMITH_PROJECT: LangSmith project name for Thread capture orchestration traces.
LANGSMITH_PROJECT=thread-capture-orchestration

# LANGCHAIN_PROJECT: LangChain SDK project mirror; defaults to LANGSMITH_PROJECT when unset.
LANGCHAIN_PROJECT=${LANGSMITH_PROJECT}

# LANGSMITH_ENDPOINT: LangSmith API base (change only for self-hosted or regional endpoints).
LANGSMITH_ENDPOINT=https://api.smith.langchain.com